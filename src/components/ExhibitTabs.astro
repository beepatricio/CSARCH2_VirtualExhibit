---
// full-width tab bar that switches between sibling panels

const { tabs } = Astro.props;
// tabs: [{ id: "overview", label: "Overview" }, ...]
---

<div class="xt-tabs" id="xt-tabs">
  {tabs.map((tab, i) => (
    <button
      type="button"
      class="xt-tabs__btn"
      data-tab-target={tab.id}
      aria-selected={i === 0 ? "true" : "false"}
    >
      {tab.label}
    </button>
  ))}
</div>

<script>
  function initTabs() {
    const bar = document.getElementById('xt-tabs');
    if (!bar) return;

    const buttons = Array.from(bar.querySelectorAll<HTMLButtonElement>('[data-tab-target]'));
    const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-tab-panel]'));

    function activate(id: string, updateHash = true) {
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.tabPanel !== id;
      });
      buttons.forEach((btn) => {
        const isActive = btn.dataset.tabTarget === id;
        btn.setAttribute('aria-selected', String(isActive));
      });
      if (updateHash) {
        history.replaceState(null, '', `#${id}`);
      }

      // notify any listeners that this panel just became visible
      document.dispatchEvent(new CustomEvent('xt-tab-activated', { detail: { id } }));
    }

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        if (btn.dataset.tabTarget) activate(btn.dataset.tabTarget);
      });
    });

    // Honor a direct link like page#stages on load. Otherwise default to the
    // first tab WITHOUT writing a hash to the URL — writing "#overview" would
    // make the browser auto-scroll to the element with id="overview" (native
    // anchor-scroll behavior), skipping past the title hero image above it.
    const requestedHash = window.location.hash.replace('#', '');
    const initial = requestedHash || buttons[0]?.dataset.tabTarget;
    if (initial) {
      activate(initial, Boolean(requestedHash));
      if (!requestedHash) {
        // guarantee we land at the very top of the page on a fresh visit
        window.scrollTo(0, 0);
      }
    }
  }

  document.addEventListener('DOMContentLoaded', initTabs);
</script>