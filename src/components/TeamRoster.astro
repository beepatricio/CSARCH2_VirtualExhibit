---
import "../styles/exhibit-theme.css";

interface Member {
  name: string;
  role: string;
}
interface Props {
  members: Member[];
}
const { members } = Astro.props;
const stageColors = ["#eb4b3a", "#3fae5c", "#f2a52c", "#4fc3e8", "#a86bd9"];
---

<div class="exhibit-theme xt-roster">
  {members.map((m, i) => (
    <div class="xt-card" style={`--accent: ${stageColors[i % stageColors.length]}`}>
      <div class="xt-card-badge">xd</div>
      <div class="xt-card-name">{m.name}</div>
      <div class="xt-card-role">{m.role}</div>
    </div>
  ))}
</div>

<style>
  .xt-roster {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    margin: 2rem 0;
  }
  .xt-card {
    background: #ffffff;
    border: 3px solid var(--xt-fg);
    border-radius: 18px;
    box-shadow: 5px 5px 0 var(--xt-fg);
    padding: 26px 18px;
    text-align: center;
    transition: transform 0.15s ease;
  }
  .xt-card:hover { transform: translateY(-4px); }
  .xt-card-badge {
    width: 56px;
    height: 56px;
    margin: 0 auto 14px;
    border-radius: 50%;
    background: var(--accent);
    border: 3px solid var(--xt-fg);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 26px;
  }
  .xt-card-name {
    font-family: var(--xt-display);
    font-weight: 800;
    font-size: 17px;
    text-transform: uppercase;
    color: var(--xt-fg);
  }
  .xt-card-role {
    margin-top: 6px;
    font-family: "Nunito", sans-serif;
    font-weight: 700;
    font-size: 13px;
    color: var(--xt-fg-mute);
  }
</style>